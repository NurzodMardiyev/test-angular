<div class="flex min-h-screen bg-gray-100">
  <!-- Sidebar -->
  <aside class="w-64 bg-gray-900 text-gray-100 flex flex-col shadow-lg">
    <!-- Header -->
    <header class="p-4 border-b border-gray-800">
      <h1 class="text-lg font-semibold text-white">Bojxona toвЂlovlari</h1>
    </header>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto p-2">
      <ul class="space-y-1">
        <ng-container *ngFor="let item of items">
          <li>
            <!-- Category -->
            <div
              (click)="toggleDropdown(item.label!, item)"
              [ngClass]="{
                'menu-active': isActive(item),
                'hover:bg-gray-800': !isActive(item)
              }"
              class="flex items-center justify-between px-3 py-2 text-sm rounded-md cursor-pointer transition"
            >
              <div class="flex items-center gap-2">
                <i [class]="item.icon"></i>
                <span>{{ item.label }}</span>
              </div>

              <i
                *ngIf="item.items?.length"
                class="pi transition-transform duration-300"
                [ngClass]="isOpen(item.label!) ? 'pi-chevron-down rotate-180' : 'pi-chevron-right'"
              ></i>
            </div>

            <!-- Submenus -->
            <ul
              *ngIf="item.items && isOpen(item.label!)"
              class="ml-4 border-l border-gray-800 pl-2 mt-1 space-y-1 transition-all duration-300"
            >
              <ng-container *ngFor="let sub of item.items">
                <li>
                  <div
                    (click)="toggleDropdown(sub.label!, sub)"
                    [ngClass]="{
                      'submenu-active': isActive(sub),
                      'hover:bg-gray-800 text-gray-300': !isActive(sub)
                    }"
                    class="flex items-center justify-between px-3 py-2 text-sm rounded-md cursor-pointer transition"
                  >
                    <div class="flex items-center gap-2">
                      <i *ngIf="sub.icon" [class]="sub.icon"></i>
                      <span>{{ sub.label }}</span>
                    </div>

                    <i
                      *ngIf="sub.items?.length"
                      class="pi transition-transform duration-300"
                      [ngClass]="isOpen(sub.label!) ? 'pi-chevron-down rotate-180' : 'pi-chevron-right'"
                    ></i>
                  </div>

                  <!-- Inner submenu -->
                  <ng-container *ngIf="sub.items && isOpen(sub.label!)">
                    <ul class="ml-4 border-l border-gray-800 pl-2 mt-1 space-y-1">
                      <li
                        *ngFor="let inner of sub.items"
                        (click)="toggleDropdown(inner.label!, inner)"
                        [ngClass]="{
                          'submenu-active': isActive(inner),
                          'hover:bg-gray-800 text-gray-400': !isActive(inner)
                        }"
                        class="px-3 py-2 text-sm rounded-md cursor-pointer transition"
                      >
                        <div class="flex items-center gap-2">
                          <i *ngIf="inner.icon" [class]="inner.icon"></i>
                          <span>{{ inner.label }}</span>
                        </div>
                      </li>
                    </ul>
                  </ng-container>
                </li>
              </ng-container>
            </ul>
          </li>
        </ng-container>
      </ul>
    </nav>

    <!-- Footer: til tanlash va logout -->
    <footer class="border-t border-gray-800 p-3 mt-auto bg-gray-900">
      <div class="flex items-center justify-between">
        <!-- Language bar -->
        <div class="flex items-center gap-3">
          <button
            *ngFor="let lang of langs"
            (click)="switchLang(lang.code)"
            class="flex flex-col items-center justify-center text-xs font-medium px-2 py-1 rounded-md transition"
            [ngClass]="{
          'bg-gray-800 text-white': currentLang === lang.code,
          'text-gray-400 hover:text-white hover:bg-gray-800': currentLang !== lang.code
        }"
          >
            <span class="text-lg leading-none">{{ lang.flag }}</span>
            <span class="uppercase text-[10px] tracking-wide">{{ lang.code }}</span>
          </button>
        </div>

        <!-- Logout -->
        <button
          (click)="logout()"
          class="flex items-center gap-2 text-sm px-2 py-1 rounded hover:bg-gray-800 transition"
        >
          <i class="pi pi-sign-out text-gray-400"></i>
          <span>Chiqish</span>
        </button>
      </div>
    </footer>
  </aside>

  <!-- Main content -->
  <main class="flex-1 p-6">
    <app-content></app-content>
  </main>
</div>
